<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
Export options for `xcodebuild -exportArchive`. Used by
desktop/scripts/build-all.sh (Track C C2).

method=app-store — targets App Store Connect / TestFlight. The same
archive passes Gatekeeper via notarisation + stapling (Apple
Distribution certs produce a chain Gatekeeper treats as
Notarized Developer ID for standalone exec checks).

signingStyle=manual — avoids auto-provisioning surprises in CI and on
shared machines where Xcode might otherwise refresh a stale profile
silently. Requires the provisioning profile below to be installed at
~/Library/MobileDevice/Provisioning Profiles/.

teamID Z56GZVA2QB — Bristlenose / Martin Storey.
Provisioning profile "Bristlenose Mac App Store" — bundle ID
app.bristlenose, issued against the Apple Distribution cert.

uploadSymbols=false — PyInstaller strips symbols from the sidecar,
so symbolicating inside Python is a non-starter anyway. Swift dSYMs
land in the .xcarchive; upload is C3's concern.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>
    <key>teamID</key>
    <string>Z56GZVA2QB</string>
    <key>signingStyle</key>
    <string>manual</string>
    <key>signingCertificate</key>
    <string>Apple Distribution</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>app.bristlenose</key>
        <string>Bristlenose Mac App Store</string>
    </dict>
    <key>destination</key>
    <string>export</string>
    <key>uploadSymbols</key>
    <false/>
</dict>
</plist>
