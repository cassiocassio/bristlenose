{
  "name": "bristlenose-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "size-limit": [
    {
      "name": "Live SPA, English (gzipped)",
      "path": [
        "../bristlenose/server/static/assets/*.js",
        "!../bristlenose/server/static/assets/visual-diff-*.js",
        "!../bristlenose/server/static/assets/ResponsivePlayground-*.js",
        "!../bristlenose/server/static/assets/PlaygroundStore-*.js",
        "!../bristlenose/server/static/assets/PlaygroundHUD-*.js",
        "!../bristlenose/server/static/assets/devicePresets-*.js",
        "!../bristlenose/server/static/assets/HelloIsland-*.js",
        "!../bristlenose/server/static/assets/common-*.js",
        "!../bristlenose/server/static/assets/settings-*.js",
        "!../bristlenose/server/static/assets/desktop-*.js",
        "!../bristlenose/server/static/assets/enums-*.js",
        "!../bristlenose/server/static/assets/cli-*.js",
        "!../bristlenose/server/static/assets/doctor-*.js",
        "!../bristlenose/server/static/assets/pipeline-*.js",
        "!../bristlenose/server/static/assets/server-*.js"
      ],
      "limit": "210 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "i18next": "^26.0.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "jsdom": "^27.4.0",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
